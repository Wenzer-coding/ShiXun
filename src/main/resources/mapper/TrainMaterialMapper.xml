<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.eutmp.app.mapper.TrainMaterialMapper">
    
    <resultMap id="BaseResultMap" type="com.eutmp.app.bean.TrainMaterial">
        <id column="id" property="id"/>
        <result column="material_name" property="materialName"/>
        <result column="spec" property="spec"/>
        <result column="unit" property="unit"/>
        <result column="price" property="price"/>
        <result column="stock_num" property="stockNum"/>
        <result column="warn_num" property="warnNum"/>
        <result column="remark" property="remark"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>
    
    <sql id="Base_Column_List">
        id, material_name, spec, unit, price, stock_num, warn_num, remark, status, create_time, update_time
    </sql>
    
    <select id="selectById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/> FROM train_material WHERE id = #{id}
    </select>
    
    <select id="selectAll" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/> FROM train_material
        <where>
            <if test="materialName != null and materialName != ''">AND material_name LIKE CONCAT('%', #{materialName}, '%')</if>
            <if test="status != null">AND status = #{status}</if>
        </where>
        ORDER BY create_time DESC
    </select>
    
    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO train_material (material_name, spec, unit, price, stock_num, warn_num, remark, status, create_time, update_time)
        VALUES (#{materialName}, #{spec}, #{unit}, #{price}, #{stockNum}, #{warnNum}, #{remark}, #{status}, #{createTime}, #{updateTime})
    </insert>
    
    <update id="update">
        UPDATE train_material
        <set>
            <if test="materialName != null">material_name = #{materialName},</if>
            <if test="spec != null">spec = #{spec},</if>
            <if test="unit != null">unit = #{unit},</if>
            <if test="price != null">price = #{price},</if>
            <if test="stockNum != null">stock_num = #{stockNum},</if>
            <if test="warnNum != null">warn_num = #{warnNum},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="status != null">status = #{status},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </set>
        WHERE id = #{id}
    </update>
    
    <delete id="deleteById">DELETE FROM train_material WHERE id = #{id}</delete>
    
    <delete id="deleteByIds">
        DELETE FROM train_material WHERE id IN
        <foreach item="id" collection="ids" open="(" separator="," close=")">#{id}</foreach>
    </delete>
    
</mapper>
