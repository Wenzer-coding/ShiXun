<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.eutmp.app.mapper.SysUserRoleMapper">
    
    <!-- 结果映射 -->
    <resultMap id="BaseResultMap" type="com.eutmp.app.bean.SysUserRole">
        <id column="id" property="id" jdbcType="BIGINT"/>
        <result column="user_id" property="userId" jdbcType="BIGINT"/>
        <result column="role_id" property="roleId" jdbcType="BIGINT"/>
    </resultMap>
    
    <!-- 基础列 -->
    <sql id="Base_Column_List">
        id, user_id, role_id
    </sql>
    
    <!-- 根据ID查询 -->
    <select id="selectById" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM sys_user_role
        WHERE id = #{id}
    </select>
    
    <!-- 根据用户ID查询 -->
    <select id="selectByUserId" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM sys_user_role
        WHERE user_id = #{userId}
    </select>
    
    <!-- 根据角色ID查询 -->
    <select id="selectByRoleId" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM sys_user_role
        WHERE role_id = #{roleId}
    </select>
    
    <!-- 新增 -->
    <insert id="insert" parameterType="com.eutmp.app.bean.SysUserRole" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO sys_user_role (
            user_id, role_id
        ) VALUES (
            #{userId}, #{roleId}
        )
    </insert>
    
    <!-- 批量新增 -->
    <insert id="batchInsert" parameterType="java.util.List">
        INSERT INTO sys_user_role (user_id, role_id) VALUES
        <foreach collection="list" item="item" separator=",">
            (#{item.userId}, #{item.roleId})
        </foreach>
    </insert>
    
    <!-- 根据用户ID删除 -->
    <delete id="deleteByUserId">
        DELETE FROM sys_user_role WHERE user_id = #{userId}
    </delete>
    
    <!-- 根据用户ID和角色ID列表批量删除 -->
    <delete id="batchDeleteByUserIdAndRoleIds">
        DELETE FROM sys_user_role 
        WHERE user_id = #{userId} 
        AND role_id IN
        <foreach collection="roleIds" item="roleId" open="(" separator="," close=")">
            #{roleId}
        </foreach>
    </delete>
    
    <!-- 删除 -->
    <delete id="deleteById">
        DELETE FROM sys_user_role WHERE id = #{id}
    </delete>
    
</mapper>
